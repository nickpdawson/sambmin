    },
    {
      "id": "UF-02",
      "name": "Password Reset (Help Desk)",
      "actor": "Help Desk",
      "steps": [
        "Search user",
        "Open drawer",
        "Reset Password modal",
        "Enter/generate password",
        "Toggle must-change",
        "Confirm",
        "Audit logged"
      ]
    },
    {
      "id": "UF-03",
      "name": "Account Lockout Investigation",
      "actor": "Help Desk",
