    {
      "id": "UF-04",
      "name": "DNS Record Troubleshooting",
      "actor": "DNS Admin",
      "steps": [
        "Dashboard DNS alert",
        "Diagnostics page",
        "SRV validator matrix",
        "Fix missing records",
        "Verify with cross-DC checker"
      ]
    },
    {
      "id": "UF-05",
      "name": "Replication Failure Response",
      "actor": "Full Admin",
      "steps": [
        "Dashboard replication alert",
        "Topology view",
        "Identify failed link",
        "Force sync",
        "Monitor convergence",
        "LDAP compare if persistent"
      ]
    },
    {
      "id": "UF-06",
      "name": "Employee Offboarding",
      "actor": "User Admin",
      "steps": [
        "Search user",
        "Disable account",
        "Remove from groups",
        "Move to Disabled Users OU",
        "Set expiration date"
      ]
    },
    {
      "id": "UF-07",
      "name": "Self-Service Password Change",
      "actor": "Any user",
      "steps": [
        "Self-Service Portal",
        "Change Password form",
        "Current + new + confirm",
        "Inline policy validation",
        "Submit"
      ]
    },
    {
      "id": "UF-08",
      "name": "Bulk User Import",
      "actor": "User Admin",
      "steps": [
        "Upload CSV/JSON",
        "Dry-run validation",
        "Fix errors or skip",
        "Execute",
        "Results summary"
      ]
    },
    {
      "id": "UF-09",
      "name": "Service Account Provisioning",
      "actor": "Full Admin",
      "steps": [
        "Create with service defaults",
        "Add SPNs",
        "Configure delegation",
        "Set auth policy",
        "Generate keytab"
      ]
    },
    {
      "id": "UF-10",
      "name": "DNS Aging Setup",
      "actor": "DNS Admin",
      "steps": [
        "Zone Properties",
        "Configure Aging",
        "Set intervals",
        "Preview timeline",
        "Bulk mark critical as static",
        "Confirm"
      ]
    }
  ],
