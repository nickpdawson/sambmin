{
  "product": {
    "name": "Sambmin",
    "version": "1.0",
    "date": "2026-02-18",
    "license": "GPLv3",
    "status": "Active Development \u2014 M13",
    "author": "Nick Dawson, CTO / Head of DevOps, DZsec",
    "description": "Web-based Samba Active Directory management tool providing full parity with Windows RSAT/ADUC through a modern, secure interface.",
    "design_philosophy": "Calm Power"
  },
  "architecture": {
    "stack": {
      "backend": "Go (net/http, gokrb5, go-ldap, pgx)",
      "scripts": "Python 3.11+ (samba-tool wrappers)",
      "frontend": "React 18 + TypeScript + Vite + Ant Design 5",
      "visualization": "D3.js + React",
      "database": "PostgreSQL 15+",
      "proxy": "nginx",
      "process_mgmt": "FreeBSD rc.d / systemd",
      "tls": "Let's Encrypt or local CA"
    },
    "decisions": [
      "LDAP for reads, samba-tool for writes",
      "Two-tier auth: service account reads, user credential writes",
      "PostgreSQL for app data only (never AD data)",
      "DNS backend abstraction (Samba internal vs BIND9 DLZ)",
      "Kerberos abstraction (Heimdal vs MIT)",
      "Multi-DC awareness with failover"
    ],
    "target_environment": {
      "dc_count": "3-6",
      "site_count": "2-4",
      "os": [
        "FreeBSD 14+",
        "Linux"
      ],
      "samba_version": "4.15+",
      "dns_backends": [
        "Samba internal DNS",
        "BIND9 DLZ"
      ],
      "kerberos_backends": [
        "Heimdal",
        "MIT"
      ]
    }
  },
  "authentication": {
    "methods": [
      {
        "type": "Kerberos/SPNEGO",
        "description": "nginx Negotiate header to Go API"
      },
      {
        "type": "LDAP bind",
        "description": "Username+password, supports sAMAccountName/UPN/DN"
      }
    ],
    "session": {
      "storage": "PostgreSQL",
      "encryption": "AES-256-GCM",
      "timeout": "8h",
      "csrf": "SameSite+token"
    },
    "rbac": [
      {
        "role": "Full Admin",
        "group": "Domain Admins, Enterprise Admins",
        "scope": "Everything"
      },
      {
        "role": "User Admin",
        "group": "Account Operators, custom",
        "scope": "User/group CRUD, password resets"
      },
      {
        "role": "DNS Admin",
        "group": "DnsAdmins, custom",
        "scope": "DNS zone/record CRUD"
      },
      {
        "role": "Help Desk",
        "group": "Custom",
        "scope": "Password reset, unlock, view all"
      },
      {
        "role": "Read Only",
        "group": "Domain Users",
        "scope": "View everything"
      }
    ],
    "self_service": [
      "Change own password",
      "Edit profile fields",
      "View groups",
      "View certs",
      "View account status"
    ]
  },
