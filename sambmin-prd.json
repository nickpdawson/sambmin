  "development_phases": [
    {
      "phase": 1,
      "name": "Foundation",
      "status": "completed",
      "milestones": "M1-M12",
      "summary": "Project scaffold, app shell, all directory pages, live LDAP, auth, write ops, deployment"
    },
    {
      "phase": 2,
      "name": "Completeness",
      "status": "in_progress",
      "milestones": "M13+",
      "summary": "Write ops debugging, self-service, full user properties, contacts, rename, search, password policies"
    },
    {
      "phase": 3,
      "name": "DNS Deep Dive",
      "status": "planned",
      "summary": "Server info, zone properties, aging/scavenging, query tool, consistency checker, bulk ops"
    },
    {
      "phase": 4,
      "name": "Infrastructure & Replication",
      "status": "planned",
      "summary": "D3.js topology, replication status, LDAP compare, sites & subnets"
    },
    {
      "phase": 5,
      "name": "Policy & Security",
      "status": "planned",
      "summary": "GPO, Kerberos/SPNs, auth policies/silos, FSMO, schema, trusts, delegation"
    },
    {
      "phase": 6,
      "name": "Operations & Polish",
      "status": "planned",
      "summary": "Service accounts, certificates, backup/restore, audit, webhooks, settings"
    }
  ],
  "samba_limitations": [
    {
      "feature": "DNS conditional forwarders",
      "status": "Not implemented",
      "approach": "Info banner"
    },
    {
      "feature": "DNS zone transfers",
      "status": "Not implemented (AD replication used)",
      "approach": "Info banner"
    },
    {
      "feature": "DNS scavenging",
      "status": "Aging supported, auto-scavenging limited",
      "approach": "App-level scavenging job"
    },
    {
      "feature": "DNS forwarder config",
      "status": "smb.conf only",
      "approach": "Display config, explain change requires smb.conf"
    },
    {
      "feature": "DNSSEC",
      "status": "Not supported",
      "approach": "Info banner"
    },
    {
      "feature": "Trust relationships",
      "status": "Experimental",
      "approach": "Warning with specific limitations"
    },
    {
      "feature": "GPO enforcement on DCs",
      "status": "Not supported",
      "approach": "Explain; use passwordsettings instead"
    },
    {
      "feature": "gMSA",
      "status": "Partial",
      "approach": "Display if supported, note limitations"
    },
    {
      "feature": "AD Recycle Bin",
      "status": "Supported at sufficient forest level",
      "approach": "Implement if level allows"
    }
  ],
