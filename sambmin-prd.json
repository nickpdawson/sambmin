  "user_flows": [
    {
      "id": "UF-01",
      "name": "New Employee Onboarding",
      "actor": "User Admin / Full Admin",
      "steps": [
        "Create User form",
        "Progressive disclosure: name/username/password then department/title/manager/groups/OU",
        "Password generator with policy validation",
        "Review with samba-tool equivalent",
        "Submit"
