#!/bin/sh
#
# PROVIDE: sambmin
# REQUIRE: DAEMON samba_server
# KEYWORD: shutdown
#
# Add the following lines to /etc/rc.conf to enable sambmin:
#
# sambmin_enable="YES"
#
# Optional rc.conf variables:
# sambmin_config="/home/administrator/sambmin/config.yaml"
# sambmin_secrets="/home/administrator/sambmin/secrets.env"
# sambmin_user="administrator"
# sambmin_group="administrator"

. /etc/rc.subr

name="sambmin"
rcvar="${name}_enable"

load_rc_config $name

: ${sambmin_enable:="NO"}
: ${sambmin_user:="administrator"}
: ${sambmin_group:="administrator"}
: ${sambmin_dir:="/home/administrator/sambmin"}
: ${sambmin_config:="${sambmin_dir}/config.yaml"}
: ${sambmin_secrets:="${sambmin_dir}/secrets.env"}
: ${sambmin_pidfile:="/var/run/${name}.pid"}
: ${sambmin_logfile:="/var/log/${name}.log"}

pidfile="${sambmin_pidfile}"
command="${sambmin_dir}/sambmin"
command_interpreter=""

start_cmd="${name}_start"
stop_cmd="${name}_stop"
status_cmd="${name}_status"
restart_cmd="${name}_restart"

sambmin_start()
{
    if [ -f "${pidfile}" ] && kill -0 $(cat "${pidfile}") 2>/dev/null; then
        echo "${name} is already running (pid $(cat ${pidfile}))."
        return 1
    fi

    echo "Starting ${name}."

    # Source secrets file for SAMBMIN_BIND_PW
    if [ -f "${sambmin_secrets}" ]; then
        . "${sambmin_secrets}"
        export SAMBMIN_BIND_PW
    fi

    export SAMBMIN_CONFIG="${sambmin_config}"

    install -o ${sambmin_user} -g ${sambmin_group} -m 0644 /dev/null ${sambmin_logfile} 2>/dev/null

    /usr/sbin/daemon -f -p ${pidfile} -u ${sambmin_user} \
        ${command} >> ${sambmin_logfile} 2>&1

    sleep 1
    if [ -f "${pidfile}" ] && kill -0 $(cat "${pidfile}") 2>/dev/null; then
        echo "${name} started (pid $(cat ${pidfile}))."
    else
        echo "${name} failed to start. Check ${sambmin_logfile}"
        return 1
    fi
}

sambmin_stop()
{
    if [ -f "${pidfile}" ]; then
        pid=$(cat "${pidfile}")
        if kill -0 ${pid} 2>/dev/null; then
            echo "Stopping ${name} (pid ${pid})."
            kill ${pid}
            wait_for_pids ${pid}
            rm -f ${pidfile}
        else
            echo "${name} is not running (stale pidfile)."
            rm -f ${pidfile}
        fi
    else
        echo "${name} is not running."
    fi
}

sambmin_status()
{
    if [ -f "${pidfile}" ] && kill -0 $(cat "${pidfile}") 2>/dev/null; then
        echo "${name} is running (pid $(cat ${pidfile}))."
    else
        echo "${name} is not running."
        return 1
    fi
}

sambmin_restart()
{
    sambmin_stop
    sleep 1
    sambmin_start
}

run_rc_command "$1"
